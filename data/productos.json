{
  "contrato": "DOSIS-DATA-CONTRACT",
  "version": "1.0",
  "descripcion": "Contrato de datos oficial del Sistema DOSIS. Estructura unica de producto compartida por Web, Fabrica de Fotos, GitHub y n8n. Todos los sistemas deben leer y escribir usando este esquema.",
  "generado": "2026-07-07",
  "moneda": "ARS",
  "rutaImagenes": "imagenes/productos/",
  "esquemaProducto": {
    "id": "string · identificador unico interno (obligatorio)",
    "codigo": "string · codigo/SKU del proveedor",
    "nombre": "string · nombre comercial del producto (obligatorio)",
    "categoria": "string · categoria principal (Buzos, Jeans, Calzado, etc.)",
    "subcategoria": "string · subcategoria opcional (Frisa, Canguro, etc.)",
    "marca": "string · marca del producto",
    "genero": "string · Hombre | Mujer | Unisex | Ninos",
    "talles": "array<string> · talles disponibles",
    "color": "string · color principal",
    "precio": "number|null · precio de venta actual en ARS",
    "precioAnterior": "number|null · precio previo para mostrar tachado",
    "descuento": "number|null · porcentaje de descuento (0-100)",
    "descripcion": "string · descripcion del producto",
    "imagenPrincipal": "string · ruta relativa de la foto principal",
    "imagenes": "array<string> · rutas relativas de fotos adicionales",
    "stock": "boolean · true si hay disponibilidad",
    "destacado": "boolean · true para mostrar en secciones destacadas",
    "nuevo": "boolean · true para marcar como novedad",
    "temporada": "string · Invierno | Verano | Otono | Primavera | Todo el ano",
    "whatsapp": "boolean · true si habilita el boton Consultar por WhatsApp"
  },
